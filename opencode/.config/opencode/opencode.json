{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-antigravity-auth@latest"],
  "mcp": {
    "k3s-homelab": {
      "type": "local",
      "enabled": false,
      "command": [
        "podman",
        "run",
        "-i",
        "--rm",
        "--net=host",
        "--security-opt", "label=disable",
        "-v", "/var/home/agfonseca/.kube/config:/kubeconfig:ro,Z",
        "-e", "KUBECONFIG=/kubeconfig",
        "-e", "ALLOW_ONLY_NON_DESTRUCTIVE_TOOLS=true",
        "docker.io/library/node:20-slim",
        "npx",
        "-y",
        "mcp-server-kubernetes"
      ]
    },
    "biblioteca-aws": {
      "type": "local",
      "enabled": false,
      "command": [
        "podman",
        "run",
        "-i",
        "--rm",
        "--userns=keep-id",
        "--security-opt", "label=disable",
        "-v", "/var/home/agfonseca/Workspace/repos/DOP-C02-Pipeline-Lab/study_material:/projects/study_material:ro,Z",
        "-v", "/var/home/agfonseca/Workspace/repos/DOP-C02-Pipeline-Lab:/projects/code:ro,Z",
        "docker.io/library/node:20-slim",
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/projects/study_material",
        "/projects/code"
      ]
    }
  }
}
